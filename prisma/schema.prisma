generator client {
  provider   = "prisma-client-js"
  output     = "../node_modules/.prisma/client"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

model User {
  id                        String                      @id @default(cuid())
  email                     String                      @unique
  name                      String
  passwordHash              String
  role                      UserRole                    @default(SALES)
  isActive                  Boolean                     @default(true)
  lastLogin                 DateTime?
  ipAddress                 String?
  phone                     String?
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  companyId                 String?
  auditLogs                 AuditLog[]
  createdClientPOs          ClientPurchaseOrder[]       @relation("CPOCreatedBy")
  csApproved                ComparativeStatement[]      @relation("CSApprovedBy")
  csPrepared                ComparativeStatement[]      @relation("CSPreparedBy")
  employee                  EmployeeMaster?
  receivedGRNs              GoodsReceiptNote[]          @relation("ReceivedBy")
  heatEntriesAdded          HeatEntry[]                 @relation("HEAddedBy")
  mtcDocumentsAdded         HeatMTCDocument[]           @relation("MTCAddedBy")
  inspections               Inspection[]                @relation("InspectorUser")
  inspectionOffersApproved  InspectionOffer[]           @relation("IOApprovedBy")
  createdInspectionOffers   InspectionOffer[]           @relation("IOCreatedBy")
  inspectionOffersRejected  InspectionOffer[]           @relation("IORejectedBy")
  inspectionPrepsCreated    InspectionPrep[]            @relation("IPPreparedBy")
  invoiceEmailsSent         InvoiceEmailLog[]           @relation("InvoiceEmailSentBy")
  generatedLabLetters       LabLetter[]                 @relation("LabLetterGeneratedBy")
  uploadedLabReports        LabReport[]                 @relation("LabReportUploadedBy")
  mtcCertificatesCreated    MTCCertificate[]            @relation("MTCCertCreatedBy")
  closedNCRs                NCR[]                       @relation("NCRClosedBy")
  responsibleNCRs           NCR[]                       @relation("NCRResponsiblePerson")
  verifiedNCRs              NCR[]                       @relation("NCRVerifiedBy")
  orderProcessingItems      OrderProcessingItem[]       @relation("OrderProcessedBy")
  createdPOAcceptances      POAcceptance[]              @relation("POACreatedBy")
  poaEmailsSent             POAcceptanceEmailLog[]      @relation("POAEmailSentBy")
  approvedPRs               PurchaseRequisition[]       @relation("PRApprovedBy")
  requestedPRs              PurchaseRequisition[]       @relation("PRRequestedBy")
  qcReleases                QCRelease[]                 @relation("ReleasedBy")
  approvedQuotations        Quotation[]                 @relation("ApprovedBy")
  ownedQuotations           Quotation[]                 @relation("DealOwner")
  preparedQuotations        Quotation[]                 @relation("PreparedBy")
  emailsSent                QuotationEmailLog[]         @relation("EmailSentBy")
  rfqsCreated               RFQ[]                       @relation("RFQCreatedBy")
  rateRevisions             RateRevision[]              @relation("RateRevisionChangedBy")
  authorizedStockIssues     StockIssue[]                @relation("AuthorizedBy")
  issuedStockIssues         StockIssue[]                @relation("IssuedBy")
  supplierQuotationsCreated SupplierQuotation[]         @relation("SQCreatedBy")
  sqDocsUploaded            SupplierQuotationDocument[] @relation("SQDocUploadedBy")
  tendersCreated            Tender[]                    @relation("TenderCreatedBy")
  tenderDocsUploaded        TenderDocument[]            @relation("TenderDocUploadedBy")
  company                   CompanyMaster?              @relation(fields: [companyId], references: [id])
  approvedVendors           VendorMaster[]              @relation("VendorApprovedBy")
  assignedMPRs              WarehouseIntimation[]       @relation("MPRAssignedTo")
  createdMPRs               WarehouseIntimation[]       @relation("MPRCreatedBy")

  @@index([email])
  @@index([companyId])
}

model CustomerMaster {
  id                    String                    @id @default(cuid())
  name                  String
  addressLine1          String?
  addressLine2          String?
  city                  String?
  state                 String?
  country               String                    @default("India")
  pincode               String?
  gstNo                 String?
  contactPerson         String?
  email                 String?
  phone                 String?
  paymentTerms          String?
  currency              String                    @default("INR")
  isActive              Boolean                   @default(true)
  companyType           CompanyType               @default(BUYER)
  gstType               GSTType?
  contactPersonEmail    String?
  contactPersonPhone    String?
  openingBalance        Decimal                   @default(0.00) @db.Decimal(14, 2)
  creditLimit           Decimal?                  @db.Decimal(14, 2)
  creditDays            Int?
  defaultPaymentTermsId String?
  defaultCurrency       String                    @default("INR")
  companyReferenceCode  String?
  pan                   String?
  industrySegment       String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  bankAccountNo         String?
  bankAccountType       String?
  bankBranchName        String?
  bankIfsc              String?
  bankName              String?
  tanNo                 String?
  companyId             String?
  customerType          String                    @default("DOMESTIC")
  buyers                BuyerMaster[]
  clientPurchaseOrders  ClientPurchaseOrder[]
  customerContacts      CustomerContact[]
  dispatchAddresses     CustomerDispatchAddress[]
  company               CompanyMaster?            @relation(fields: [companyId], references: [id])
  defaultPaymentTerms   PaymentTermsMaster?       @relation(fields: [defaultPaymentTermsId], references: [id])
  tags                  CustomerTag[]
  termDefaults          CustomerTermDefault[]
  inspectionOffers      InspectionOffer[]
  invoices              Invoice[]
  mtcCertificates       MTCCertificate[]          @relation("MTCCertCustomer")
  paymentReceipts       PaymentReceipt[]
  quotations            Quotation[]
  salesOrders           SalesOrder[]
  tenders               Tender[]                  @relation("TenderCustomer")
  linkedVendor          VendorMaster?             @relation("LinkedCustomerVendor")

  @@index([companyId])
  @@index([companyType])
  @@index([defaultPaymentTermsId], map: "CustomerMaster_defaultPaymentTermsId_fkey")
}

model CustomerTermDefault {
  id            String         @id @default(cuid())
  customerId    String
  termName      String
  termValue     String
  sortOrder     Int            @default(0)
  quotationType String         @default("DOMESTIC")
  isIncluded    Boolean        @default(true)
  customer      CustomerMaster @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, termName, quotationType])
  @@index([customerId])
}

model VendorMaster {
  id                   String                 @id @default(cuid())
  name                 String
  addressLine1         String?
  addressLine2         String?
  city                 String?
  state                String?
  country              String                 @default("India")
  pincode              String?
  approvedStatus       Boolean                @default(false)
  productsSupplied     String?
  avgLeadTimeDays      Int?
  performanceScore     Decimal?               @db.Decimal(3, 1)
  contactPerson        String?
  email                String?
  phone                String?
  isActive             Boolean                @default(true)
  linkedCustomerId     String?                @unique
  gstNo                String?
  gstType              GSTType?
  bankAccountNo        String?
  bankIfsc             String?
  bankName             String?
  vendorRating         Decimal?               @db.Decimal(3, 1)
  approvalDate         DateTime?
  pan                  String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  approvalRemarks      String?
  approvedById         String?
  bankAccountType      String?
  bankBranchName       String?
  tanNo                String?
  companyId            String?
  csEntries            CSEntry[]
  selectedInCS         ComparativeStatement[] @relation("CSSelectedVendor")
  goodsReceiptNotes    GoodsReceiptNote[]
  ncrs                 NCR[]
  purchaseOrders       PurchaseOrder[]
  purchaseRequisitions PurchaseRequisition[]  @relation("PRVendor")
  rfqVendors           RFQVendor[]
  supplierQuotations   SupplierQuotation[]    @relation("SQVendor")
  approvedBy           User?                  @relation("VendorApprovedBy", fields: [approvedById], references: [id])
  company              CompanyMaster?         @relation(fields: [companyId], references: [id])
  linkedCustomer       CustomerMaster?        @relation("LinkedCustomerVendor", fields: [linkedCustomerId], references: [id])

  @@index([companyId])
  @@index([approvedById], map: "VendorMaster_approvedById_fkey")
}

model ProductSpecMaster {
  id                    String                     @id @default(cuid())
  product               String
  material              String?
  additionalSpec        String?
  ends                  String?
  length                String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  category              ProductCategory?
  dimensionalStandardId String?
  grade                 String?
  specification         String?
  companyId             String?
  dimensionalStandard   DimensionalStandardMaster? @relation(fields: [dimensionalStandardId], references: [id])

  @@index([category])
  @@index([dimensionalStandardId])
}

model AdditionalSpecOption {
  id        String   @id @default(cuid())
  product   String
  specName  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  companyId String?

  @@unique([product, specName])
  @@index([product])
}

model SizeMaster {
  id             String          @id @default(cuid())
  sizeLabel      String
  od             Decimal         @db.Decimal(10, 3)
  wt             Decimal         @db.Decimal(10, 3)
  weight         Decimal         @db.Decimal(10, 4)
  pipeType       PipeType
  nps            Decimal?        @db.Decimal(6, 3)
  schedule       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  companyId      String?
  quotationItems QuotationItem[]

  @@index([pipeType])
  @@index([sizeLabel])
  @@index([nps])
  @@index([nps, schedule])
  @@map("PipeSizeMaster")
}

model TestingMaster {
  id            String   @id @default(cuid())
  testName      String
  applicableFor String?
  isMandatory   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  companyId     String?
}

model LengthMaster {
  id        String   @id @default(cuid())
  label     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  companyId String?
}

model TaxMaster {
  id            String    @id @default(cuid())
  name          String
  code          String?
  percentage    Decimal   @db.Decimal(5, 2)
  taxType       String?
  hsnCode       String?
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CurrencyMaster {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  symbol       String
  exchangeRate Decimal  @db.Decimal(10, 4)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UomMaster {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaymentTermsMaster {
  id          String           @id @default(cuid())
  code        String?
  name        String
  description String?
  days        Int              @default(30)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  companyId   String?
  customers   CustomerMaster[]
  quotations  Quotation[]
}

model DeliveryTermsMaster {
  id          String      @id @default(cuid())
  code        String?
  name        String
  description String?
  incoterms   String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  companyId   String?
  quotations  Quotation[]
}

model InspectionAgencyMaster {
  id                   String               @id @default(cuid())
  name                 String
  code                 String               @unique
  contactPerson        String?
  phone                String?
  email                String?
  address              String?
  accreditationDetails String?
  approvedStatus       Boolean              @default(true)
  isActive             Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  companyId            String?
  inspections          Inspection[]
  inspectionOffers     InspectionOffer[]    @relation("IOTpiAgency")
  labLetters           LabLetter[]
  qualityRequirements  QualityRequirement[]
}

model QualityRequirement {
  id                   String                  @id @default(cuid())
  companyId            String?
  parameter            String
  value                String?                 @db.Text
  colourCodingRequired Boolean                 @default(false)
  inspectionRequired   Boolean                 @default(false)
  tpiAgencyId          String?
  testingRequired      Boolean                 @default(false)
  testType             String?
  inspectionLocation   String?
  qapDocumentPath      String?
  remarks              String?                 @db.Text
  isActive             Boolean                 @default(true)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  company              CompanyMaster?          @relation(fields: [companyId], references: [id])
  tpiAgency            InspectionAgencyMaster? @relation(fields: [tpiAgencyId], references: [id])

  @@index([companyId])
  @@index([parameter])
  @@index([tpiAgencyId])
}

model CertificationTypeMaster {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DimensionalStandardMaster {
  id        String              @id @default(cuid())
  name      String
  code      String              @unique
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  companyId String?
  products  ProductSpecMaster[]
}

model TransporterMaster {
  id            String         @id @default(cuid())
  name          String
  contactPerson String?
  phone         String?
  vehicleTypes  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  dispatchNotes DispatchNote[]
}

model Quotation {
  id                   String                @id @default(cuid())
  quotationNo          String
  quotationDate        DateTime              @default(now())
  customerId           String
  quotationType        QuotationType         @default(DOMESTIC)
  quotationCategory    QuotationCategory     @default(STANDARD)
  status               QuotationStatus       @default(DRAFT)
  version              Int                   @default(0)
  parentQuotationId    String?
  validUpto            DateTime?
  currency             String                @default("INR")
  paymentTermsId       String?
  deliveryTermsId      String?
  deliveryPeriod       String?
  preparedById         String?
  approvedById         String?
  approvalDate         DateTime?
  approvalRemarks      String?
  sentDate             DateTime?
  sentTo               String?
  buyerId              String?
  preparedByEmployeeId String?
  subtotal             Decimal?              @db.Decimal(14, 2)
  taxRate              Decimal?              @db.Decimal(5, 2)
  taxAmount            Decimal?              @db.Decimal(14, 2)
  grandTotal           Decimal?              @db.Decimal(14, 2)
  amountInWords        String?
  revisionTrigger      String?
  revisionSubReason    String?
  revisionNotes        String?               @db.Text
  customerReference    String?
  inquiryNo            String?
  inquiryDate          DateTime?
  changeSnapshot       String?               @db.LongText
  expiryNotified7d     Boolean               @default(false)
  expiryNotified3d     Boolean               @default(false)
  expiryNotified1d     Boolean               @default(false)
  lossReason           String?
  lossCompetitor       String?
  lossNotes            String?               @db.Text
  dealOwnerId          String?
  nextActionDate       DateTime?
  kindAttention        String?               @db.VarChar(200)
  additionalDiscount   Decimal?              @db.Decimal(10, 2)
  discountAmount       Decimal?              @db.Decimal(14, 2)
  totalAfterDiscount   Decimal?              @db.Decimal(14, 2)
  rcmEnabled           Boolean               @default(false)
  roundOff             Boolean               @default(false)
  roundOffAmount       Decimal?              @db.Decimal(10, 2)
  advanceToPay         Decimal?              @db.Decimal(14, 2)
  placeOfSupplyCity    String?
  placeOfSupplyState   String?
  placeOfSupplyCountry String?               @default("India")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  companyId            String?
  sourceTenderId       String?
  clientPurchaseOrders ClientPurchaseOrder[]
  mtcCertificates      MTCCertificate[]
  approvedBy           User?                 @relation("ApprovedBy", fields: [approvedById], references: [id])
  buyer                BuyerMaster?          @relation(fields: [buyerId], references: [id])
  company              CompanyMaster?        @relation(fields: [companyId], references: [id])
  customer             CustomerMaster        @relation(fields: [customerId], references: [id])
  dealOwner            User?                 @relation("DealOwner", fields: [dealOwnerId], references: [id])
  deliveryTerms        DeliveryTermsMaster?  @relation(fields: [deliveryTermsId], references: [id])
  parentQuotation      Quotation?            @relation("QuotationRevisions", fields: [parentQuotationId], references: [id])
  childQuotations      Quotation[]           @relation("QuotationRevisions")
  paymentTerms         PaymentTermsMaster?   @relation(fields: [paymentTermsId], references: [id])
  preparedByEmployee   EmployeeMaster?       @relation(fields: [preparedByEmployeeId], references: [id])
  preparedBy           User?                 @relation("PreparedBy", fields: [preparedById], references: [id])
  sourceTender         Tender?               @relation("TenderQuotations", fields: [sourceTenderId], references: [id])
  emailLogs            QuotationEmailLog[]
  items                QuotationItem[]
  terms                QuotationTerm[]
  salesOrders          SalesOrder[]

  @@unique([quotationNo, version])
  @@index([quotationNo])
  @@index([customerId])
  @@index([buyerId])
  @@index([quotationCategory])
  @@index([parentQuotationId])
  @@index([status])
  @@index([validUpto])
  @@index([customerId, status])
  @@index([preparedById, status])
  @@index([revisionTrigger])
  @@index([companyId])
  @@index([dealOwnerId])
  @@index([nextActionDate])
  @@index([approvedById], map: "Quotation_approvedById_fkey")
  @@index([deliveryTermsId], map: "Quotation_deliveryTermsId_fkey")
  @@index([paymentTermsId], map: "Quotation_paymentTermsId_fkey")
  @@index([preparedByEmployeeId], map: "Quotation_preparedByEmployeeId_fkey")
  @@index([sourceTenderId], map: "Quotation_sourceTenderId_fkey")
}

model QuotationEmailLog {
  id           String         @id @default(cuid())
  quotationId  String
  sentTo       String
  sentCc       String?
  subject      String
  messageBody  String         @db.Text
  sentById     String?
  sentAt       DateTime       @default(now())
  status       EmailLogStatus
  errorMessage String?        @db.Text
  quotation    Quotation      @relation(fields: [quotationId], references: [id])
  sentBy       User?          @relation("EmailSentBy", fields: [sentById], references: [id])

  @@index([quotationId])
  @@index([sentById])
}

model QuotationItem {
  id                String              @id @default(cuid())
  quotationId       String
  sNo               Int
  product           String?
  material          String?
  additionalSpec    String?
  sizeId            String?
  sizeLabel         String?
  od                Decimal?            @db.Decimal(10, 3)
  wt                Decimal?            @db.Decimal(10, 3)
  length            String?
  ends              String?
  quantity          Decimal             @db.Decimal(10, 3)
  materialCost      Decimal?            @db.Decimal(12, 2)
  logisticsCost     Decimal?            @db.Decimal(12, 2)
  inspectionCost    Decimal?            @db.Decimal(12, 2)
  otherCosts        Decimal?            @db.Decimal(12, 2)
  totalCostPerUnit  Decimal?            @db.Decimal(12, 2)
  marginPercentage  Decimal?            @db.Decimal(5, 2)
  unitRate          Decimal             @db.Decimal(12, 2)
  amount            Decimal             @db.Decimal(14, 2)
  delivery          String?
  remark            String?
  unitWeight        Decimal?            @db.Decimal(10, 4)
  totalWeightMT     Decimal?            @db.Decimal(12, 4)
  tagNo             String?
  drawingRef        String?
  itemDescription   String?             @db.Text
  certificateReq    String?
  itemType          String?
  wtType            String?
  tubeLength        String?
  tubeCount         Int?
  componentPosition String?
  sizeNPS           Decimal?            @db.Decimal(6, 3)
  schedule          String?
  materialCodeId    String?
  uom               String?
  hsnCode           String?
  taxRate           Decimal?            @db.Decimal(5, 2)
  fittingId         String?
  flangeId          String?
  pastPo            String?
  pastPoPrice       Decimal?            @db.Decimal(12, 2)
  pastQuote         String?
  pastQuotePrice    Decimal?            @db.Decimal(12, 2)
  materialCodeLabel String?
  clientPOItems     ClientPOItem[]
  fitting           FittingMaster?      @relation(fields: [fittingId], references: [id])
  flange            FlangeMaster?       @relation(fields: [flangeId], references: [id])
  materialCode      MaterialCodeMaster? @relation(fields: [materialCodeId], references: [id])
  quotation         Quotation           @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  pipeSize          SizeMaster?         @relation(fields: [sizeId], references: [id])

  @@index([quotationId])
  @@index([materialCodeId])
  @@index([fittingId])
  @@index([flangeId])
  @@index([sizeId], map: "QuotationItem_sizeId_fkey")
}

model QuotationTerm {
  id                String    @id @default(cuid())
  quotationId       String
  termNo            Int
  termName          String
  termValue         String
  isDefault         Boolean   @default(true)
  isIncluded        Boolean   @default(true)
  isCustom          Boolean   @default(false)
  isHeadingEditable Boolean   @default(false)
  quotation         Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
}

model CompanyMaster {
  id                    String                 @id @default(cuid())
  companyName           String
  companyType           String?
  regAddressLine1       String?
  regAddressLine2       String?
  regCity               String?
  regPincode            String?
  regState              String?
  regCountry            String                 @default("India")
  whAddressLine1        String?
  whAddressLine2        String?
  whCity                String?
  whPincode             String?
  whState               String?
  whCountry             String                 @default("India")
  panNo                 String?
  tanNo                 String?
  gstNo                 String?
  cinNo                 String?
  telephoneNo           String?
  email                 String?
  website               String?
  companyLogoUrl        String?
  fyStartMonth          Int                    @default(4)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  fyEndDate             DateTime?
  fyStartDate           DateTime?
  isoLogoUrl            String?
  alerts                Alert[]
  auditLogs             AuditLog[]
  clientPurchaseOrders  ClientPurchaseOrder[]
  comparativeStatements ComparativeStatement[]
  customers             CustomerMaster[]
  dispatchNotes         DispatchNote[]
  documentSequences     DocumentSequence[]
  employees             EmployeeMaster[]
  goodsReceiptNotes     GoodsReceiptNote[]
  inspections           Inspection[]
  inspectionOffers      InspectionOffer[]
  inspectionPreps       InspectionPrep[]
  inventoryStocks       InventoryStock[]
  invoices              Invoice[]
  labLetters            LabLetter[]
  labReports            LabReport[]
  mtcCertificates       MTCCertificate[]       @relation("MTCCertCompany")
  mtcMaterialSpecs      MTCMaterialSpec[]
  mtcNoteMasters        MTCNoteMaster[]
  ncrs                  NCR[]
  offerTermTemplates    OfferTermTemplate[]
  orderProcessingItems  OrderProcessingItem[]
  poAcceptances         POAcceptance[]
  packingLists          PackingList[]
  paymentReceipts       PaymentReceipt[]
  purchaseOrders        PurchaseOrder[]
  purchaseRequisitions  PurchaseRequisition[]
  qcReleases            QCRelease[]
  qualityRequirements   QualityRequirement[]
  quotations            Quotation[]
  rfqs                  RFQ[]
  rateRevisions         RateRevision[]
  salesOrders           SalesOrder[]
  stockIssues           StockIssue[]
  supplierQuotations    SupplierQuotation[]    @relation("SQCompany")
  tenders               Tender[]
  users                 User[]
  vendors               VendorMaster[]
  warehouseIntimations  WarehouseIntimation[]
  warehouses            WarehouseMaster[]
}

model FinancialYear {
  id        String   @id @default(cuid())
  label     String   @unique
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model EmployeeMaster {
  id                 String         @id @default(cuid())
  employeeCode       String         @unique
  name               String
  department         String?
  designation        String?
  email              String?
  mobile             String?
  linkedUserId       String?        @unique
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  moduleAccess       String?        @db.LongText
  companyId          String?
  company            CompanyMaster? @relation(fields: [companyId], references: [id])
  linkedUser         User?          @relation(fields: [linkedUserId], references: [id])
  quotationsPrepared Quotation[]

  @@index([companyId])
}

model BuyerMaster {
  id          String         @id @default(cuid())
  customerId  String
  buyerName   String
  designation String?
  email       String?
  mobile      String?
  telephone   String?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  companyId   String?
  customer    CustomerMaster @relation(fields: [customerId], references: [id])
  quotations  Quotation[]

  @@index([customerId])
}

model CustomerDispatchAddress {
  id            String         @id @default(cuid())
  customerId    String
  label         String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  pincode       String?
  state         String?
  country       String         @default("India")
  consigneeName String?
  placeOfSupply String?
  isDefault     Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  companyName   String?
  contactNumber String?
  contactPerson String?
  gstNo         String?
