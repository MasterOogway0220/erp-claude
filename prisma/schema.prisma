generator client {
  provider   = "prisma-client-js"
  output     = "../node_modules/.prisma/client"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

// ==================== ENUMS ====================

enum UserRole {
  SUPER_ADMIN
  SALES
  PURCHASE
  QC
  STORES
  ACCOUNTS
  MANAGEMENT
}

enum StockStatus {
  UNDER_INSPECTION
  ACCEPTED
  REJECTED
  HOLD
  RESERVED
  DISPATCHED
}

enum QuotationType {
  DOMESTIC
  EXPORT
  BOM
}

enum QuotationStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  REVISED
  SENT
  WON
  LOST
  EXPIRED
  SUPERSEDED
  CANCELLED
}

enum SOStatus {
  OPEN
  PARTIALLY_DISPATCHED
  FULLY_DISPATCHED
  CLOSED
  CANCELLED
}

enum POStatus {
  DRAFT
  PENDING_APPROVAL
  OPEN
  SENT_TO_VENDOR
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CLOSED
  CANCELLED
}

enum PRStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PO_CREATED
}

enum NCRStatus {
  OPEN
  UNDER_INVESTIGATION
  CORRECTIVE_ACTION_IN_PROGRESS
  CLOSED
  VERIFIED
}

enum NCRDisposition {
  RETURN_TO_VENDOR
  REWORK
  SCRAP
  USE_AS_IS
}

enum InspectionResult {
  PASS
  FAIL
  HOLD
}

enum StockIssueStatus {
  DRAFT
  PENDING_AUTHORIZATION
  AUTHORIZED
  REJECTED
}

enum PaymentMode {
  RTGS
  NEFT
  CHEQUE
  DD
  LC
  TT
  CASH
}

enum InvoiceType {
  DOMESTIC
  EXPORT
  PROFORMA
  CREDIT_NOTE
  DEBIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum RequisitionType {
  AGAINST_SO
  STOCK_REPLENISHMENT
  EMERGENCY
}

enum POAcceptanceStatus {
  PENDING
  ACCEPTED
  REJECTED
  HOLD
}

enum ClientPOStatus {
  DRAFT
  REGISTERED
  PARTIALLY_FULFILLED
  FULLY_FULFILLED
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  SUBMIT_FOR_APPROVAL
  VOID
  LOGIN
  LOGOUT
  STATUS_CHANGE
  EXPORT
  EMAIL_SENT
}

enum PipeType {
  CS_AS
  SS_DS
}

enum EndType {
  BE
  PE
  NPTM
  BSPT
}

enum MTCType {
  MTC_3_1
  MTC_3_2
}

enum MPRStatus {
  PENDING
  IN_PROGRESS
  MATERIAL_READY
  DISPATCHED
  CANCELLED
}

enum MPRPriority {
  NORMAL
  URGENT
  CRITICAL
}

enum MPRItemStatus {
  PENDING
  PREPARING
  READY
  ISSUED
}

enum MPRCheckStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  NA
}

enum ReservationStatus {
  RESERVED
  RELEASED
  DISPATCHED
}

enum LabReportType {
  CHEMICAL
  MECHANICAL
  HYDRO
  IMPACT
  IGC
}

enum CompanyType {
  BUYER
  SUPPLIER
  BOTH
}

enum GSTType {
  REGULAR
  COMPOSITION
  UNREGISTERED
  SEZ
}

enum QuotationCategory {
  STANDARD
  NON_STANDARD
}

enum EmailLogStatus {
  SUCCESS
  FAILED
}

enum ContactDepartment {
  FOLLOW_UP
  QUALITY_INSPECTION
  ACCOUNTS
  OTHER
}

enum ProductCategory {
  PIPES
  FITTINGS
  FLANGES
  VALVES
  NUT_BOLT
  GASKETS
}

enum AlertType {
  INSPECTION_DUE
  LAB_TESTING_PENDING
  DELIVERY_DEADLINE
  MATERIAL_PREPARATION
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  UNREAD
  READ
  DISMISSED
}

// ==================== USER & AUTH ====================

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         UserRole  @default(SALES)
  companyId    String?
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  ipAddress    String?
  phone        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  company                 CompanyMaster?        @relation(fields: [companyId], references: [id])
  preparedQuotations      Quotation[]           @relation("PreparedBy")
  approvedQuotations      Quotation[]           @relation("ApprovedBy")
  ownedQuotations         Quotation[]           @relation("DealOwner")
  approvedPRs             PurchaseRequisition[] @relation("PRApprovedBy")
  requestedPRs            PurchaseRequisition[] @relation("PRRequestedBy")
  receivedGRNs            GoodsReceiptNote[]    @relation("ReceivedBy")
  inspections             Inspection[]          @relation("InspectorUser")
  closedNCRs              NCR[]                 @relation("NCRClosedBy")
  responsibleNCRs         NCR[]                 @relation("NCRResponsiblePerson")
  verifiedNCRs            NCR[]                 @relation("NCRVerifiedBy")
  generatedLabLetters     LabLetter[]           @relation("LabLetterGeneratedBy")
  auditLogs               AuditLog[]
  employee                EmployeeMaster?
  issuedStockIssues       StockIssue[]          @relation("IssuedBy")
  authorizedStockIssues   StockIssue[]          @relation("AuthorizedBy")
  qcReleases              QCRelease[]           @relation("ReleasedBy")
  emailsSent              QuotationEmailLog[]   @relation("EmailSentBy")
  invoiceEmailsSent       InvoiceEmailLog[]     @relation("InvoiceEmailSentBy")
  approvedVendors         VendorMaster[]        @relation("VendorApprovedBy")
  createdClientPOs        ClientPurchaseOrder[] @relation("CPOCreatedBy")
  createdPOAcceptances    POAcceptance[]        @relation("POACreatedBy")
  createdMPRs             WarehouseIntimation[] @relation("MPRCreatedBy")
  assignedMPRs            WarehouseIntimation[] @relation("MPRAssignedTo")
  createdInspectionOffers InspectionOffer[]     @relation("IOCreatedBy")
  uploadedLabReports      LabReport[]           @relation("LabReportUploadedBy")

  @@index([email])
  @@index([companyId])
}

// ==================== MASTER DATA ====================

model CustomerMaster {
  id                    String      @id @default(cuid())
  companyId             String?
  name                  String
  addressLine1          String?
  addressLine2          String?
  city                  String?
  state                 String?
  country               String      @default("India")
  pincode               String?
  gstNo                 String?
  contactPerson         String?
  email                 String?
  phone                 String?
  paymentTerms          String?
  currency              String      @default("INR")
  isActive              Boolean     @default(true)
  companyType           CompanyType @default(BUYER)
  gstType               GSTType?
  contactPersonEmail    String?
  contactPersonPhone    String?
  openingBalance        Decimal     @default(0) @db.Decimal(14, 2)
  creditLimit           Decimal?    @db.Decimal(14, 2)
  creditDays            Int?
  defaultPaymentTermsId String?
  defaultCurrency       String      @default("INR")
  companyReferenceCode  String?
  pan                   String?
  tanNo                 String?
  industrySegment       String?
  bankName              String?
  bankBranchName        String?
  bankAccountNo         String?
  bankIfsc              String?
  bankAccountType       String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  // Relations
  company              CompanyMaster?            @relation(fields: [companyId], references: [id])
  quotations           Quotation[]
  salesOrders          SalesOrder[]
  invoices             Invoice[]
  paymentReceipts      PaymentReceipt[]
  defaultPaymentTerms  PaymentTermsMaster?       @relation(fields: [defaultPaymentTermsId], references: [id])
  dispatchAddresses    CustomerDispatchAddress[]
  buyers               BuyerMaster[]
  tags                 CustomerTag[]
  linkedVendor         VendorMaster?             @relation("LinkedCustomerVendor")
  clientPurchaseOrders ClientPurchaseOrder[]
  customerContacts     CustomerContact[]
  inspectionOffers     InspectionOffer[]

  @@index([companyId])
  @@index([companyType])
}

model VendorMaster {
  id               String    @id @default(cuid())
  companyId        String?
  name             String
  addressLine1     String?
  addressLine2     String?
  city             String?
  state            String?
  country          String    @default("India")
  pincode          String?
  approvedStatus   Boolean   @default(false)
  productsSupplied String?
  avgLeadTimeDays  Int?
  performanceScore Decimal?  @db.Decimal(3, 1)
  contactPerson    String?
  email            String?
  phone            String?
  isActive         Boolean   @default(true)
  linkedCustomerId String?   @unique
  gstNo            String?
  gstType          GSTType?
  bankAccountNo    String?
  bankIfsc         String?
  bankName         String?
  bankBranchName   String?
  bankAccountType  String?
  tanNo            String?
  vendorRating     Decimal?  @db.Decimal(3, 1)
  approvalDate     DateTime?
  approvedById     String?
  approvalRemarks  String?
  pan              String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  company              CompanyMaster?        @relation(fields: [companyId], references: [id])
  approvedBy           User?                 @relation("VendorApprovedBy", fields: [approvedById], references: [id])
  purchaseRequisitions PurchaseRequisition[] @relation("PRVendor")
  purchaseOrders       PurchaseOrder[]
  goodsReceiptNotes    GoodsReceiptNote[]
  ncrs                 NCR[]
  linkedCustomer       CustomerMaster?       @relation("LinkedCustomerVendor", fields: [linkedCustomerId], references: [id])

  @@index([companyId])
}

model ProductSpecMaster {
  id                    String           @id @default(cuid())
  product               String
  category              ProductCategory?
  specification         String?
  grade                 String?
  material              String?
  additionalSpec        String?
  ends                  String?
  length                String?
  dimensionalStandardId String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  dimensionalStandard DimensionalStandardMaster? @relation(fields: [dimensionalStandardId], references: [id])

  @@index([category])
  @@index([dimensionalStandardId])
}

model SizeMaster {
  id        String   @id @default(cuid())
  sizeLabel String
  od        Decimal  @db.Decimal(10, 3)
  wt        Decimal  @db.Decimal(10, 3)
  weight    Decimal  @db.Decimal(10, 4)
  pipeType  PipeType
  nps       Decimal? @db.Decimal(6, 3)
  schedule  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  quotationItems QuotationItem[]

  @@index([pipeType])
  @@index([sizeLabel])
  @@index([nps])
  @@index([nps, schedule])
  @@map("PipeSizeMaster")
}

model TestingMaster {
  id            String   @id @default(cuid())
  testName      String
  applicableFor String?
  isMandatory   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LengthMaster {
  id        String   @id @default(cuid())
  label     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaxMaster {
  id            String    @id @default(cuid())
  name          String
  code          String?
  percentage    Decimal   @db.Decimal(5, 2)
  taxType       String?
  hsnCode       String?
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CurrencyMaster {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  symbol       String
  exchangeRate Decimal  @db.Decimal(10, 4)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UomMaster {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaymentTermsMaster {
  id          String   @id @default(cuid())
  code        String?
  name        String
  description String?
  days        Int      @default(30)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  customers  CustomerMaster[]
  quotations Quotation[]
}

model DeliveryTermsMaster {
  id          String   @id @default(cuid())
  code        String?
  name        String
  description String?
  incoterms   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  quotations Quotation[]
}

model InspectionAgencyMaster {
  id                   String   @id @default(cuid())
  name                 String
  code                 String   @unique
  contactPerson        String?
  phone                String?
  email                String?
  address              String?
  accreditationDetails String?
  approvedStatus       Boolean  @default(true)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  qualityRequirements QualityRequirement[]
  inspections         Inspection[]
  inspectionOffers    InspectionOffer[]    @relation("IOTpiAgency")
  labLetters          LabLetter[]
}

model QualityRequirement {
  id                   String   @id @default(cuid())
  companyId            String?
  parameter            String // Quality parameter name (e.g., "Hardness", "Chemical Composition")
  value                String?  @db.Text // Required value/specification
  colourCodingRequired Boolean  @default(false)
  inspectionRequired   Boolean  @default(false)
  tpiAgencyId          String? // Third-Party Inspection Agency
  testingRequired      Boolean  @default(false)
  testType             String? // HYDRO, CHEMICAL, MECHANICAL, IGC, IMPACT
  inspectionLocation   String? // WAREHOUSE, LAB
  qapDocumentPath      String? // Uploaded QAP document path
  remarks              String?  @db.Text
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  company   CompanyMaster?          @relation(fields: [companyId], references: [id])
  tpiAgency InspectionAgencyMaster? @relation(fields: [tpiAgencyId], references: [id])

  @@index([companyId])
  @@index([parameter])
  @@index([tpiAgencyId])
}

model CertificationTypeMaster {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DimensionalStandardMaster {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products ProductSpecMaster[]
}

model TransporterMaster {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?
  phone         String?
  vehicleTypes  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  dispatchNotes DispatchNote[]
}

// ==================== QUOTATION ====================

model Quotation {
  id                   String            @id @default(cuid())
  companyId            String?
  quotationNo          String
  quotationDate        DateTime          @default(now())
  customerId           String
  quotationType        QuotationType     @default(DOMESTIC)
  quotationCategory    QuotationCategory @default(STANDARD)
  status               QuotationStatus   @default(DRAFT)
  version              Int               @default(0)
  parentQuotationId    String?
  validUpto            DateTime?
  currency             String            @default("INR")
  paymentTermsId       String?
  deliveryTermsId      String?
  deliveryPeriod       String?
  preparedById         String?
  approvedById         String?
  approvalDate         DateTime?
  approvalRemarks      String?
  sentDate             DateTime?
  sentTo               String?
  buyerId              String?
  preparedByEmployeeId String?
  subtotal             Decimal?          @db.Decimal(14, 2)
  taxRate              Decimal?          @db.Decimal(5, 2)
  taxAmount            Decimal?          @db.Decimal(14, 2)
  grandTotal           Decimal?          @db.Decimal(14, 2)
  amountInWords        String?

  // Revision tracking
  revisionTrigger   String?
  revisionSubReason String?
  revisionNotes     String? @db.Text
  customerReference String?

  // Client inquiry reference
  inquiryNo   String?
  inquiryDate DateTime?

  // Change tracking
  changeSnapshot Json?

  // Expiry management
  expiryNotified7d Boolean @default(false)
  expiryNotified3d Boolean @default(false)
  expiryNotified1d Boolean @default(false)

  // Loss tracking
  lossReason     String?
  lossCompetitor String?
  lossNotes      String? @db.Text

  // Deal management (TranZact parity)
  dealOwnerId    String?
  nextActionDate DateTime?
  kindAttention  String?   @db.VarChar(200)

  // Discount & financial calculations
  additionalDiscount Decimal? @db.Decimal(10, 2) // percentage discount
  discountAmount     Decimal? @db.Decimal(14, 2) // calculated: subtotal * additionalDiscount / 100
  totalAfterDiscount Decimal? @db.Decimal(14, 2) // subtotal - discountAmount
  rcmEnabled         Boolean  @default(false)
  roundOff           Boolean  @default(false)
  roundOffAmount     Decimal? @db.Decimal(10, 2)
  advanceToPay       Decimal? @db.Decimal(14, 2)

  // Place of supply (GST compliance)
  placeOfSupplyCity    String?
  placeOfSupplyState   String?
  placeOfSupplyCountry String? @default("India")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  company              CompanyMaster?        @relation(fields: [companyId], references: [id])
  customer             CustomerMaster        @relation(fields: [customerId], references: [id])
  parentQuotation      Quotation?            @relation("QuotationRevisions", fields: [parentQuotationId], references: [id])
  childQuotations      Quotation[]           @relation("QuotationRevisions")
  preparedBy           User?                 @relation("PreparedBy", fields: [preparedById], references: [id])
  approvedBy           User?                 @relation("ApprovedBy", fields: [approvedById], references: [id])
  dealOwner            User?                 @relation("DealOwner", fields: [dealOwnerId], references: [id])
  buyer                BuyerMaster?          @relation(fields: [buyerId], references: [id])
  preparedByEmployee   EmployeeMaster?       @relation(fields: [preparedByEmployeeId], references: [id])
  paymentTerms         PaymentTermsMaster?   @relation(fields: [paymentTermsId], references: [id])
  deliveryTerms        DeliveryTermsMaster?  @relation(fields: [deliveryTermsId], references: [id])
  items                QuotationItem[]
  terms                QuotationTerm[]
  salesOrders          SalesOrder[]
  clientPurchaseOrders ClientPurchaseOrder[]
  emailLogs            QuotationEmailLog[]

  @@unique([quotationNo, version])
  @@index([quotationNo])
  @@index([customerId])
  @@index([buyerId])
  @@index([quotationCategory])
  @@index([parentQuotationId])
  @@index([status])
  @@index([validUpto])
  @@index([customerId, status])
  @@index([preparedById, status])
  @@index([revisionTrigger])
  @@index([companyId])
  @@index([dealOwnerId])
  @@index([nextActionDate])
}

model QuotationEmailLog {
  id           String         @id @default(cuid())
  quotationId  String
  sentTo       String
  sentCc       String?
  subject      String
  messageBody  String         @db.Text
  sentById     String?
  sentAt       DateTime       @default(now())
  status       EmailLogStatus
  errorMessage String?        @db.Text

  quotation Quotation @relation(fields: [quotationId], references: [id])
  sentBy    User?     @relation("EmailSentBy", fields: [sentById], references: [id])

  @@index([quotationId])
  @@index([sentById])
}

model QuotationItem {
  id                String   @id @default(cuid())
  quotationId       String
  sNo               Int
  product           String?
  material          String?
  additionalSpec    String?
  sizeId            String?
  sizeLabel         String?
  od                Decimal? @db.Decimal(10, 3)
  wt                Decimal? @db.Decimal(10, 3)
  length            String?
  ends              String?
  quantity          Decimal  @db.Decimal(10, 3)
  materialCost      Decimal? @db.Decimal(12, 2)
  logisticsCost     Decimal? @db.Decimal(12, 2)
  inspectionCost    Decimal? @db.Decimal(12, 2)
  otherCosts        Decimal? @db.Decimal(12, 2)
  totalCostPerUnit  Decimal? @db.Decimal(12, 2)
  marginPercentage  Decimal? @db.Decimal(5, 2)
  unitRate          Decimal  @db.Decimal(12, 2)
  amount            Decimal  @db.Decimal(14, 2)
  delivery          String?
  remark            String?
  unitWeight        Decimal? @db.Decimal(10, 4)
  totalWeightMT     Decimal? @db.Decimal(12, 4)
  tagNo             String?
  drawingRef        String?
  itemDescription   String?  @db.Text
  certificateReq    String?
  itemType          String?
  wtType            String?
  tubeLength        String?
  tubeCount         Int?
  componentPosition String?
  sizeNPS           Decimal? @db.Decimal(6, 3)
  schedule          String?
  materialCodeId    String?
  uom               String?
  hsnCode           String?
  taxRate           Decimal? @db.Decimal(5, 2)

  pastQuote      String?
  pastQuotePrice Decimal? @db.Decimal(12, 2)
  pastPo         String?
  pastPoPrice    Decimal? @db.Decimal(12, 2)

  fittingId String?
  flangeId  String?

  // Relations
  quotation     Quotation           @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  pipeSize      SizeMaster?         @relation(fields: [sizeId], references: [id])
  materialCode  MaterialCodeMaster? @relation(fields: [materialCodeId], references: [id])
  fitting       FittingMaster?      @relation(fields: [fittingId], references: [id])
  flange        FlangeMaster?       @relation(fields: [flangeId], references: [id])
  clientPOItems ClientPOItem[]

  @@index([quotationId])
  @@index([materialCodeId])
  @@index([fittingId])
  @@index([flangeId])
}

model QuotationTerm {
  id                String  @id @default(cuid())
  quotationId       String
  termNo            Int
  termName          String
  termValue         String
  isDefault         Boolean @default(true)
  isIncluded        Boolean @default(true)
  isCustom          Boolean @default(false)
  isHeadingEditable Boolean @default(false)

  // Relations
  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
}

// ==================== COMPANY & EMPLOYEE ====================

model CompanyMaster {
  id              String    @id @default(cuid())
  companyName     String
  companyType     String?
  regAddressLine1 String?
  regAddressLine2 String?
  regCity         String?
  regPincode      String?
  regState        String?
  regCountry      String    @default("India")
  whAddressLine1  String?
  whAddressLine2  String?
  whCity          String?
  whPincode       String?
  whState         String?
  whCountry       String    @default("India")
  panNo           String?
  tanNo           String?
  gstNo           String?
  cinNo           String?
  telephoneNo     String?
  email           String?
  website         String?
  companyLogoUrl  String?
  fyStartMonth    Int       @default(4)
  fyStartDate     DateTime?
  fyEndDate       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Reverse relations (multi-tenancy)
  users                User[]
  customers            CustomerMaster[]
  vendors              VendorMaster[]
  employees            EmployeeMaster[]
  warehouses           WarehouseMaster[]
  quotations           Quotation[]
  salesOrders          SalesOrder[]
  purchaseRequisitions PurchaseRequisition[]
  purchaseOrders       PurchaseOrder[]
  goodsReceiptNotes    GoodsReceiptNote[]
  inventoryStocks      InventoryStock[]
  inspections          Inspection[]
  ncrs                 NCR[]
  labLetters           LabLetter[]
  stockIssues          StockIssue[]
  qcReleases           QCRelease[]
  packingLists         PackingList[]
  dispatchNotes        DispatchNote[]
  invoices             Invoice[]
  paymentReceipts      PaymentReceipt[]
  auditLogs            AuditLog[]
  documentSequences    DocumentSequence[]
  offerTermTemplates   OfferTermTemplate[]
  clientPurchaseOrders ClientPurchaseOrder[]
  poAcceptances        POAcceptance[]
  qualityRequirements  QualityRequirement[]
  warehouseIntimations WarehouseIntimation[]
  inspectionOffers     InspectionOffer[]
  labReports           LabReport[]
  alerts               Alert[]
}

model FinancialYear {
  id        String   @id @default(cuid())
  label     String   @unique
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model EmployeeMaster {
  id           String   @id @default(cuid())
  companyId    String?
  employeeCode String   @unique
  name         String
  department   String?
  designation  String?
  email        String?
  mobile       String?
  linkedUserId String?  @unique
  moduleAccess Json?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  company            CompanyMaster? @relation(fields: [companyId], references: [id])
  linkedUser         User?          @relation(fields: [linkedUserId], references: [id])
  quotationsPrepared Quotation[]

  @@index([companyId])
}

// ==================== BUYER & DISPATCH ====================

model BuyerMaster {
  id          String   @id @default(cuid())
  customerId  String
  buyerName   String
  designation String?
  email       String?
  mobile      String?
  telephone   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  customer   CustomerMaster @relation(fields: [customerId], references: [id])
  quotations Quotation[]

  @@index([customerId])
}

model CustomerDispatchAddress {
  id            String   @id @default(cuid())
  customerId    String
  label         String? // e.g., "Site Office - Mumbai", "Plant - Pune"
  companyName   String? // Company name at site (if different from customer)
  addressLine1  String?
  addressLine2  String?
  city          String?
  pincode       String?
  state         String?
  country       String   @default("India")
  contactPerson String? // Site contact person
  contactNumber String? // Site contact phone
  gstNo         String? // GST No. if different from billing
  consigneeName String?
  placeOfSupply String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  customer      CustomerMaster @relation(fields: [customerId], references: [id], onDelete: Cascade)
  salesOrders   SalesOrder[]
  dispatchNotes DispatchNote[]
  invoices      Invoice[]

  @@index([customerId])
}

// ==================== TAGS ====================

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  // Relations
  customers CustomerTag[]
}

model CustomerTag {
  id         String   @id @default(cuid())
  customerId String
  tagId      String
  createdAt  DateTime @default(now())

  // Relations
  customer CustomerMaster @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag      Tag            @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([customerId, tagId])
}

// ==================== MATERIAL CODE ====================

model MaterialCodeMaster {
  id              String    @id @default(cuid())
  code            String    @unique // Internal Item / Material Code
  clientItemCode  String? // Client's item code (if different)
  description     String?   @db.Text // Product description as per Client PO
  productType     String? // e.g., Seamless Pipe, ERW Pipe
  materialGrade   String? // e.g., SS316L, ASTM A106 GR B
  size            String? // Combined size label (e.g., 2" NB x 3.91mm)
  odSize          String? // Outer Diameter
  nbSize          String? // Nominal Bore
  thickness       String? // Wall thickness
  schedule        String? // SCH 40, SCH 80, etc.
  standard        String? // ASTM / ASME / API / IS etc.
  unit            String? // Default UOM: MTR / NOS / KG / SET / LOT
  rate            Decimal?  @db.Decimal(14, 2) // Last known / default rate
  firstQuotedDate DateTime?
  lastQuotedPrice Decimal?  @db.Decimal(12, 2)
  timesQuoted     Int       @default(0)
  timesOrdered    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  quotationItems QuotationItem[]

  @@index([clientItemCode])
  @@index([materialGrade])
  @@index([productType])
}

// ==================== FITTING MASTER ====================

model FittingMaster {
  id            String   @id @default(cuid())
  type          String // Elbow, Tee, Reducer, Cap, Coupling, Union, etc.
  size          String // NPS e.g. 1/2", 2", 4"
  schedule      String? // 40, 80, 160, XXS
  materialGrade String // ASTM A234 WPB, ASTM A403 WP304, etc.
  standard      String? // ASME B16.9, ASME B16.11, MSS SP75
  endType       String? // BW, SW, Threaded
  rating        String? // 2000#, 3000#, 6000# (for SW/Threaded)
  description   String?  @db.Text
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  quotationItems  QuotationItem[]
  poItems         POItem[]
  salesOrderItems SalesOrderItem[]

  @@index([type])
  @@index([size])
  @@index([type, size, schedule])
}

// ==================== FLANGE MASTER ====================

model FlangeMaster {
  id            String   @id @default(cuid())
  type          String // Weld Neck, Slip On, Blind, Socket Weld, Lap Joint, Threaded
  size          String // NPS
  rating        String // 150, 300, 600, 900, 1500, 2500
  materialGrade String
  standard      String? // ASME B16.5, ASME B16.47
  facing        String? // RF, FF, RTJ
  schedule      String?
  description   String?  @db.Text
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  quotationItems  QuotationItem[]
  poItems         POItem[]
  salesOrderItems SalesOrderItem[]

  @@index([type])
  @@index([size])
  @@index([type, size, rating])
}

// ==================== OFFER TERM TEMPLATE ====================

model OfferTermTemplate {
  id               String   @id @default(cuid())
  companyId        String?
  termName         String
  termDefaultValue String?
  sortOrder        Int      @default(0)
  quotationType    String   @default("DOMESTIC") // "DOMESTIC" or "EXPORT"
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company CompanyMaster? @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

// ==================== TECHNICAL EXCHANGE DETAIL ====================

model TechnicalExchangeDetail {
  id           String   @id @default(cuid())
  category     String // Quality, Testing, Documentation, Packaging, Marking, Inspection
  paramName    String
  defaultValue String?
  isMandatory  Boolean  @default(false)
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
}

// ==================== SALES ORDER ====================

model SalesOrder {
  id                 String             @id @default(cuid())
  companyId          String?
  soNo               String             @unique
  soDate             DateTime           @default(now())
  customerId         String
  quotationId        String?
  customerPoNo       String?
  customerPoDate     DateTime?
  customerPoDocument String?
  projectName        String?
  deliverySchedule   String?
  paymentTerms       String?
  dispatchAddressId  String?
  poAcceptanceStatus POAcceptanceStatus @default(PENDING)
  poReviewRemarks    String?
  status             SOStatus           @default(OPEN)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Relations
  company              CompanyMaster?           @relation(fields: [companyId], references: [id])
  customer             CustomerMaster           @relation(fields: [customerId], references: [id])
  quotation            Quotation?               @relation(fields: [quotationId], references: [id])
  dispatchAddress      CustomerDispatchAddress? @relation(fields: [dispatchAddressId], references: [id])
  items                SalesOrderItem[]
  purchaseRequisitions PurchaseRequisition[]
  purchaseOrders       PurchaseOrder[]          @relation("POSalesOrder")
  packingLists         PackingList[]
  dispatchNotes        DispatchNote[]
  invoices             Invoice[]
  stockIssues          StockIssue[]
  warehouseIntimations WarehouseIntimation[]
  inspectionOffers     InspectionOffer[]

  @@index([companyId])
  @@index([soNo])
  @@index([customerId])
  @@index([dispatchAddressId])
}

model SalesOrderItem {
  id             String    @id @default(cuid())
  salesOrderId   String
  sNo            Int
  product        String?
  material       String?
  additionalSpec String?
  sizeLabel      String?
  od             Decimal?  @db.Decimal(10, 3)
  wt             Decimal?  @db.Decimal(10, 3)
  ends           String?
  quantity       Decimal   @db.Decimal(10, 3)
  unitRate       Decimal   @db.Decimal(12, 2)
  amount         Decimal   @db.Decimal(14, 2)
  deliveryDate   DateTime?
  unitWeight     Decimal?  @db.Decimal(10, 4)
  totalWeightMT  Decimal?  @db.Decimal(12, 4)
  heatNo         String?
  qtyDispatched  Decimal   @default(0) @db.Decimal(10, 3)
  itemStatus     String    @default("OPEN")
  fittingId      String?
  flangeId       String?

  // Relations
  salesOrder               SalesOrder                @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  stockReservations        StockReservation[]
  fitting                  FittingMaster?            @relation(fields: [fittingId], references: [id])
  flange                   FlangeMaster?             @relation(fields: [flangeId], references: [id])
  warehouseIntimationItems WarehouseIntimationItem[]

  @@index([salesOrderId])
  @@index([fittingId])
  @@index([flangeId])
}

model StockReservation {
  id               String            @id @default(cuid())
  salesOrderItemId String
  inventoryStockId String
  reservedQtyMtr   Decimal           @db.Decimal(10, 3)
  reservedPieces   Int               @default(0)
  reservedDate     DateTime          @default(now())
  status           ReservationStatus @default(RESERVED)

  // Relations
  salesOrderItem SalesOrderItem @relation(fields: [salesOrderItemId], references: [id])
  inventoryStock InventoryStock @relation(fields: [inventoryStockId], references: [id])

  @@index([salesOrderItemId])
  @@index([inventoryStockId])
}

// ==================== CLIENT PURCHASE ORDER ====================

model ClientPurchaseOrder {
  id               String    @id @default(cuid())
  companyId        String?
  cpoNo            String    @unique
  cpoDate          DateTime  @default(now())
  customerId       String
  quotationId      String
  clientPoNumber   String
  clientPoDate     DateTime?
  projectName      String?
  contactPerson    String?
  paymentTerms     String?
  deliveryTerms    String?
  deliverySchedule String?
  currency         String    @default("INR")
  subtotal         Decimal?  @db.Decimal(14, 2)

  // Additional Charges
  freight                   Decimal? @db.Decimal(14, 2)
  freightTaxApplicable      Boolean  @default(false)
  tpiCharges                Decimal? @db.Decimal(14, 2)
  tpiTaxApplicable          Boolean  @default(false)
  testingCharges            Decimal? @db.Decimal(14, 2)
  testingTaxApplicable      Boolean  @default(false)
  packingForwarding         Decimal? @db.Decimal(14, 2)
  packingTaxApplicable      Boolean  @default(false)
  insurance                 Decimal? @db.Decimal(14, 2)
  insuranceTaxApplicable    Boolean  @default(false)
  otherCharges              Decimal? @db.Decimal(14, 2)
  otherChargesTaxApplicable Boolean  @default(false)

  // GST Calculation
  additionalChargesTotal Decimal? @db.Decimal(14, 2)
  taxableAmount          Decimal? @db.Decimal(14, 2)
  gstRate                Decimal? @db.Decimal(5, 2)
  cgst                   Decimal? @db.Decimal(14, 2)
  sgst                   Decimal? @db.Decimal(14, 2)
  igst                   Decimal? @db.Decimal(14, 2)
  supplierState          String?
  clientState            String?
  isInterState           Boolean  @default(false)
  roundOff               Decimal? @db.Decimal(10, 2)

  grandTotal  Decimal?       @db.Decimal(14, 2)
  remarks     String?        @db.Text
  status      ClientPOStatus @default(REGISTERED)
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  company          CompanyMaster?    @relation(fields: [companyId], references: [id])
  customer         CustomerMaster    @relation(fields: [customerId], references: [id])
  quotation        Quotation         @relation(fields: [quotationId], references: [id])
  createdBy        User?             @relation("CPOCreatedBy", fields: [createdById], references: [id])
  items            ClientPOItem[]
  poAcceptance     POAcceptance?
  inspectionOffers InspectionOffer[]

  @@index([companyId])
  @@index([cpoNo])
  @@index([customerId])
  @@index([quotationId])
}

model ClientPOItem {
  id                    String    @id @default(cuid())
  clientPurchaseOrderId String
  quotationItemId       String
  sNo                   Int
  product               String?
  material              String?
  additionalSpec        String?
  sizeLabel             String?
  od                    Decimal?  @db.Decimal(10, 3)
  wt                    Decimal?  @db.Decimal(10, 3)
  ends                  String?
  uom                   String?
  hsnCode               String?
  qtyQuoted             Decimal   @db.Decimal(10, 3)
  qtyOrdered            Decimal   @db.Decimal(10, 3)
  unitRate              Decimal   @db.Decimal(12, 2)
  amount                Decimal   @db.Decimal(14, 2)
  deliveryDate          DateTime?
  remark                String?

  // Relations
  clientPurchaseOrder ClientPurchaseOrder @relation(fields: [clientPurchaseOrderId], references: [id], onDelete: Cascade)
  quotationItem       QuotationItem       @relation(fields: [quotationItemId], references: [id])

  @@index([clientPurchaseOrderId])
  @@index([quotationItemId])
}

// ==================== PURCHASE ====================

model PurchaseRequisition {
  id                String          @id @default(cuid())
  companyId         String?
  prNo              String          @unique
  prDate            DateTime        @default(now())
  salesOrderId      String?
  requiredByDate    DateTime?
  suggestedVendorId String?
  requisitionType   RequisitionType @default(AGAINST_SO)
  status            PRStatus        @default(DRAFT)
  approvedById      String?
  approvalDate      DateTime?
  requestedById     String?
  approvalRemarks   String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  company         CompanyMaster?  @relation(fields: [companyId], references: [id])
  salesOrder      SalesOrder?     @relation(fields: [salesOrderId], references: [id])
  suggestedVendor VendorMaster?   @relation("PRVendor", fields: [suggestedVendorId], references: [id])
  approvedBy      User?           @relation("PRApprovedBy", fields: [approvedById], references: [id])
  requestedBy     User?           @relation("PRRequestedBy", fields: [requestedById], references: [id])
  items           PRItem[]
  purchaseOrders  PurchaseOrder[]

  @@index([companyId])
  @@index([prNo])
}

model PRItem {
  id             String  @id @default(cuid())
  prId           String
  sNo            Int
  product        String?
  material       String?
  additionalSpec String?
  sizeLabel      String?
  quantity       Decimal @db.Decimal(10, 3)
  uom            String?
  remarks        String?

  // Relations
  purchaseRequisition PurchaseRequisition @relation(fields: [prId], references: [id], onDelete: Cascade)

  @@index([prId])
}

model PurchaseOrder {
  id                  String    @id @default(cuid())
  companyId           String?
  poNo                String    @unique
  poDate              DateTime  @default(now())
  vendorId            String
  prId                String?
  salesOrderId        String?
  version             Int       @default(0)
  parentPoId          String?
  deliveryDate        DateTime?
  specialRequirements String?
  status              POStatus  @default(DRAFT)
  totalAmount         Decimal?  @db.Decimal(14, 2)
  currency            String    @default("INR")
  approvedById        String?
  approvalDate        DateTime?
  approvalRemarks     String?
  followUpNotes       String?   @db.Text
  paymentTerms        String?
  deliveryAddress     String?   @db.Text
  termsAndConditions  String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  company             CompanyMaster?       @relation(fields: [companyId], references: [id])
  vendor              VendorMaster         @relation(fields: [vendorId], references: [id])
  purchaseRequisition PurchaseRequisition? @relation(fields: [prId], references: [id])
  salesOrder          SalesOrder?          @relation("POSalesOrder", fields: [salesOrderId], references: [id])
  parentPo            PurchaseOrder?       @relation("POAmendments", fields: [parentPoId], references: [id])
  childPos            PurchaseOrder[]      @relation("POAmendments")
  items               POItem[]
  goodsReceiptNotes   GoodsReceiptNote[]
  mtcDocuments        MTCDocument[]
  ncrs                NCR[]
  labReports          LabReport[]

  @@index([companyId])
  @@index([poNo])
  @@index([vendorId])
}

model POItem {
  id             String    @id @default(cuid())
  poId           String
  sNo            Int
  product        String?
  material       String?
  additionalSpec String?
  sizeLabel      String?
  quantity       Decimal   @db.Decimal(10, 3)
  unitRate       Decimal   @db.Decimal(12, 2)
  amount         Decimal   @db.Decimal(14, 2)
  deliveryDate   DateTime?
  fittingId      String?
  flangeId       String?

  // Relations
  purchaseOrder PurchaseOrder  @relation(fields: [poId], references: [id], onDelete: Cascade)
  fitting       FittingMaster? @relation(fields: [fittingId], references: [id])
  flange        FlangeMaster?  @relation(fields: [flangeId], references: [id])

  @@index([poId])
  @@index([fittingId])
  @@index([flangeId])
}

// ==================== INVENTORY & GRN ====================

model GoodsReceiptNote {
  id              String    @id @default(cuid())
  companyId       String?
  grnNo           String    @unique
  grnDate         DateTime  @default(now())
  poId            String
  vendorId        String
  receivedById    String
  remarks         String?
  challanNo       String?
  challanDate     DateTime?
  vehicleNo       String?
  transporterName String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  company       CompanyMaster? @relation(fields: [companyId], references: [id])
  purchaseOrder PurchaseOrder  @relation(fields: [poId], references: [id])
  vendor        VendorMaster   @relation(fields: [vendorId], references: [id])
  receivedBy    User           @relation("ReceivedBy", fields: [receivedById], references: [id])
  items         GRNItem[]
  mtcDocuments  MTCDocument[]
  labReports    LabReport[]

  @@index([companyId])
  @@index([grnNo])
  @@index([poId])
}

model GRNItem {
  id                 String    @id @default(cuid())
  grnId              String
  sNo                Int
  product            String?
  material           String?
  specification      String?
  additionalSpec     String?
  dimensionStd       String?
  sizeLabel          String?
  ends               String?
  length             String?
  heatNo             String?
  make               String?
  receivedQtyMtr     Decimal   @db.Decimal(10, 3)
  pieces             Int       @default(0)
  mtcNo              String?
  mtcDate            DateTime?
  mtcType            String?
  tpiAgency          String?
  mtcDocumentPath    String?
  tpiCertificatePath String?

  // Relations
  grn             GoodsReceiptNote @relation(fields: [grnId], references: [id], onDelete: Cascade)
  inventoryStocks InventoryStock[]
  inspections     Inspection[]
  ncrs            NCR[]

  @@index([grnId])
  @@index([heatNo])
}

model InventoryStock {
  id                  String      @id @default(cuid())
  companyId           String?
  form                String?
  product             String?
  specification       String?
  additionalSpec      String?
  dimensionStd        String?
  sizeLabel           String?
  od                  Decimal?    @db.Decimal(10, 3)
  wt                  Decimal?    @db.Decimal(10, 3)
  ends                String?
  length              String?
  heatNo              String?
  make                String?
  quantityMtr         Decimal     @db.Decimal(10, 3)
  pieces              Int         @default(0)
  mtcNo               String?
  mtcDate             DateTime?
  mtcType             MTCType?
  tpiAgency           String?
  location            String?
  rackNo              String?
  notes               String?
  status              StockStatus @default(UNDER_INSPECTION)
  grnItemId           String?
  reservedForSO       String?
  warehouseLocationId String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Relations
  company                  CompanyMaster?            @relation(fields: [companyId], references: [id])
  grnItem                  GRNItem?                  @relation(fields: [grnItemId], references: [id])
  warehouseLocation        WarehouseLocation?        @relation(fields: [warehouseLocationId], references: [id])
  stockReservations        StockReservation[]
  inspections              Inspection[]
  mtcDocuments             MTCDocument[]
  ncrs                     NCR[]
  packingListItems         PackingListItem[]
  stockIssueItems          StockIssueItem[]
  qcReleases               QCRelease[]
  pipeDetails              PipeMaterialDetail[]
  labReports               LabReport[]
  labLetters               LabLetter[]
  warehouseIntimationItems WarehouseIntimationItem[]

  @@index([companyId])
  @@index([heatNo])
  @@index([status])
  @@index([sizeLabel])
  @@index([grnItemId])
  @@index([warehouseLocationId])
}

model PipeMaterialDetail {
  id               String    @id @default(cuid())
  inventoryStockId String
  pipeNo           Int
  length           Decimal?  @db.Decimal(10, 3)
  heatNo           String?
  make             String?
  mtcNo            String?
  mtcDate          DateTime?
  bundleNo         String?
  quantity         Int       @default(1)
  remarks          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  inventoryStock InventoryStock @relation(fields: [inventoryStockId], references: [id], onDelete: Cascade)

  @@unique([inventoryStockId, pipeNo])
  @@index([inventoryStockId])
  @@index([heatNo])
}

// ==================== QUALITY CONTROL ====================

model Inspection {
  id               String           @id @default(cuid())
  companyId        String?
  inspectionNo     String           @unique
  inspectionDate   DateTime         @default(now())
  grnItemId        String?
  inventoryStockId String?
  inspectorId      String
  inspectionType   String?
  overallResult    InspectionResult @default(HOLD)
  remarks          String?
  reportPath       String?
  tpiAgencyId      String?
  imagePaths       Json? // Array of inspection image file paths
  reportPaths      Json? // Array of inspection report file paths
  tpiSignOffPaths  Json? // Array of TPI sign-off document paths
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  company        CompanyMaster?          @relation(fields: [companyId], references: [id])
  grnItem        GRNItem?                @relation(fields: [grnItemId], references: [id])
  inventoryStock InventoryStock?         @relation(fields: [inventoryStockId], references: [id])
  inspector      User                    @relation("InspectorUser", fields: [inspectorId], references: [id])
  tpiAgency      InspectionAgencyMaster? @relation(fields: [tpiAgencyId], references: [id])
  parameters     InspectionParameter[]
  qcReleases     QCRelease[]

  @@index([companyId])
  @@index([inspectionNo])
  @@index([grnItemId])
  @@index([inventoryStockId])
  @@index([tpiAgencyId])
}

model InspectionParameter {
  id            String  @id @default(cuid())
  inspectionId  String
  parameterName String
  parameterType String  @default("PASS_FAIL")
  resultValue   String?
  standardValue String?
  tolerance     String?
  result        String?
  remarks       String?

  // Relations
  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
}

model InspectionOffer {
  id                     String    @id @default(cuid())
  companyId              String?
  offerNo                String    @unique
  offerDate              DateTime  @default(now())
  clientPurchaseOrderId  String?
  salesOrderId           String?
  customerId             String
  poNumber               String?
  projectName            String?
  inspectionLocation     String?
  proposedInspectionDate DateTime?
  tpiAgencyId            String?
  quantityReady          String?
  remarks                String?   @db.Text
  status                 String    @default("DRAFT")
  createdById            String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relations
  company             CompanyMaster?          @relation(fields: [companyId], references: [id])
  customer            CustomerMaster          @relation(fields: [customerId], references: [id])
  clientPurchaseOrder ClientPurchaseOrder?    @relation(fields: [clientPurchaseOrderId], references: [id])
  salesOrder          SalesOrder?             @relation(fields: [salesOrderId], references: [id])
  tpiAgency           InspectionAgencyMaster? @relation("IOTpiAgency", fields: [tpiAgencyId], references: [id])
  createdBy           User?                   @relation("IOCreatedBy", fields: [createdById], references: [id])
  items               InspectionOfferItem[]

  @@index([companyId])
  @@index([offerNo])
  @@index([customerId])
  @@index([clientPurchaseOrderId])
}

model InspectionOfferItem {
  id                 String  @id @default(cuid())
  inspectionOfferId  String
  sNo                Int
  product            String?
  material           String?
  sizeLabel          String?
  heatNo             String?
  specification      String?
  quantity           String?
  quantityReady      String?
  uom                String?
  colourCodeRequired Boolean @default(false)
  colourCode         String?
  remark             String?

  // Relations
  inspectionOffer InspectionOffer @relation(fields: [inspectionOfferId], references: [id], onDelete: Cascade)

  @@index([inspectionOfferId])
}

model MTCDocument {
  id                 String   @id @default(cuid())
  mtcNo              String
  heatNo             String?
  filePath           String?
  uploadDate         DateTime @default(now())
  poId               String?
  grnId              String?
  inventoryStockId   String?
  verificationStatus String?  @default("PENDING")
  remarks            String?

  // Relations
  purchaseOrder  PurchaseOrder?    @relation(fields: [poId], references: [id])
  grn            GoodsReceiptNote? @relation(fields: [grnId], references: [id])
  inventoryStock InventoryStock?   @relation(fields: [inventoryStockId], references: [id])

  @@index([heatNo])
  @@index([mtcNo])
}

model NCR {
  id                  String          @id @default(cuid())
  companyId           String?
  ncrNo               String          @unique
  ncrDate             DateTime        @default(now())
  grnItemId           String?
  inventoryStockId    String?
  heatNo              String?
  poId                String?
  vendorId            String?
  nonConformanceType  String?
  description         String?
  rootCause           String?
  correctiveAction    String?
  preventiveAction    String?
  disposition         NCRDisposition?
  status              NCRStatus       @default(OPEN)
  closedDate          DateTime?
  closedById          String?
  evidencePaths       Json?
  targetClosureDate   DateTime?
  responsiblePersonId String?
  verifiedById        String?
  verifiedDate        DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  // Relations
  company           CompanyMaster?  @relation(fields: [companyId], references: [id])
  grnItem           GRNItem?        @relation(fields: [grnItemId], references: [id])
  inventoryStock    InventoryStock? @relation(fields: [inventoryStockId], references: [id])
  purchaseOrder     PurchaseOrder?  @relation(fields: [poId], references: [id])
  vendor            VendorMaster?   @relation(fields: [vendorId], references: [id])
  closedBy          User?           @relation("NCRClosedBy", fields: [closedById], references: [id])
  responsiblePerson User?           @relation("NCRResponsiblePerson", fields: [responsiblePersonId], references: [id])
  verifiedBy        User?           @relation("NCRVerifiedBy", fields: [verifiedById], references: [id])

  @@index([companyId])
  @@index([ncrNo])
  @@index([heatNo])
}

model LabLetter {
  id                 String   @id @default(cuid())
  companyId          String?
  letterNo           String   @unique
  letterDate         DateTime @default(now())
  labName            String?
  labAddress         String?  @db.Text
  inventoryStockId   String?
  poNumber           String?
  clientName         String?
  productDescription String?  @db.Text
  itemCode           String?
  heatNo             String?
  make               String?
  specification      String?
  sizeLabel          String?
  quantity           String?
  unit               String?
  testIds            Json?
  testNames          Json?
  witnessRequired    Boolean  @default(false)
  tpiAgencyId        String?
  tpiAgencyName      String?
  status             String   @default("DRAFT")
  generatedPath      String?
  generatedById      String?
  remarks            String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company        CompanyMaster?          @relation(fields: [companyId], references: [id])
  inventoryStock InventoryStock?         @relation(fields: [inventoryStockId], references: [id])
  tpiAgency      InspectionAgencyMaster? @relation(fields: [tpiAgencyId], references: [id])
  generatedBy    User?                   @relation("LabLetterGeneratedBy", fields: [generatedById], references: [id])

  @@index([companyId])
  @@index([heatNo])
  @@index([status])
  @@index([inventoryStockId])
}

// ==================== WAREHOUSE ====================

model WarehouseMaster {
  id           String   @id @default(cuid())
  companyId    String?
  code         String   @unique
  name         String
  gstNo        String?
  addressLine1 String?
  addressLine2 String?
  pincode      String?
  state        String?
  country      String   @default("India")
  stockVisible Boolean  @default(true)
  isSelfStock  Boolean  @default(true)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  company              CompanyMaster?        @relation(fields: [companyId], references: [id])
  locations            WarehouseLocation[]
  addresses            WarehouseAddress[]
  dispatchNotes        DispatchNote[]
  invoices             Invoice[]
  packingLists         PackingList[]
  warehouseIntimations WarehouseIntimation[]

  @@index([companyId])
}

model WarehouseAddress {
  id           String   @id @default(cuid())
  warehouseId  String
  label        String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  pincode      String?
  state        String?
  country      String   @default("India")
  gstNo        String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  warehouse WarehouseMaster @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([warehouseId])
}

model WarehouseLocation {
  id                 String   @id @default(cuid())
  warehouseId        String
  zone               String?
  rack               String?
  bay                String?
  shelf              String?
  locationType       String   @default("GENERAL")
  capacity           String?
  locationTag        String?  @unique
  preservationMethod String?
  storageConditions  String?  @db.Text
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  warehouse       WarehouseMaster  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  inventoryStocks InventoryStock[]

  @@index([warehouseId])
}

// ==================== STOCK ISSUE ====================

model StockIssue {
  id             String           @id @default(cuid())
  companyId      String?
  issueNo        String           @unique
  issueDate      DateTime         @default(now())
  salesOrderId   String
  issuedById     String
  authorizedById String?
  status         StockIssueStatus @default(DRAFT)
  remarks        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  company      CompanyMaster?   @relation(fields: [companyId], references: [id])
  salesOrder   SalesOrder       @relation(fields: [salesOrderId], references: [id])
  issuedBy     User             @relation("IssuedBy", fields: [issuedById], references: [id])
  authorizedBy User?            @relation("AuthorizedBy", fields: [authorizedById], references: [id])
  items        StockIssueItem[]

  @@index([companyId])
  @@index([issueNo])
  @@index([salesOrderId])
}

model StockIssueItem {
  id               String  @id @default(cuid())
  stockIssueId     String
  inventoryStockId String
  heatNo           String?
  sizeLabel        String?
  material         String?
  quantityMtr      Decimal @db.Decimal(10, 3)
  pieces           Int     @default(0)
  location         String?

  // Relations
  stockIssue     StockIssue     @relation(fields: [stockIssueId], references: [id], onDelete: Cascade)
  inventoryStock InventoryStock @relation(fields: [inventoryStockId], references: [id])

  @@index([stockIssueId])
  @@index([inventoryStockId])
}

// ==================== QC RELEASE ====================

model QCRelease {
  id               String   @id @default(cuid())
  companyId        String?
  releaseNo        String   @unique
  releaseDate      DateTime @default(now())
  inspectionId     String
  inventoryStockId String
  decision         String   @default("ACCEPT")
  releasedById     String
  remarks          String?
  createdAt        DateTime @default(now())

  // Relations
  company        CompanyMaster? @relation(fields: [companyId], references: [id])
  inspection     Inspection     @relation(fields: [inspectionId], references: [id])
  inventoryStock InventoryStock @relation(fields: [inventoryStockId], references: [id])
  releasedBy     User           @relation("ReleasedBy", fields: [releasedById], references: [id])

  @@index([companyId])
  @@index([releaseNo])
  @@index([inspectionId])
  @@index([inventoryStockId])
}

model LabReport {
  id               String        @id @default(cuid())
  companyId        String?
  reportNo         String        @unique
  reportDate       DateTime      @default(now())
  reportType       LabReportType
  heatNo           String
  itemCode         String?
  poId             String?
  inventoryStockId String?
  grnId            String?
  filePath         String?
  fileName         String?
  labName          String?
  testDate         DateTime?
  result           String?
  remarks          String?       @db.Text
  uploadedById     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  company        CompanyMaster?    @relation(fields: [companyId], references: [id])
  purchaseOrder  PurchaseOrder?    @relation(fields: [poId], references: [id])
  inventoryStock InventoryStock?   @relation(fields: [inventoryStockId], references: [id])
  grn            GoodsReceiptNote? @relation(fields: [grnId], references: [id])
  uploadedBy     User?             @relation("LabReportUploadedBy", fields: [uploadedById], references: [id])

  @@index([companyId])
  @@index([heatNo])
  @@index([itemCode])
  @@index([poId])
  @@index([reportType])
  @@index([inventoryStockId])
}

// ==================== DISPATCH & FINANCE ====================

model PackingList {
  id           String   @id @default(cuid())
  companyId    String?
  plNo         String   @unique
  plDate       DateTime @default(now())
  salesOrderId String
  warehouseId  String?
  remarks      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  company       CompanyMaster?    @relation(fields: [companyId], references: [id])
  salesOrder    SalesOrder        @relation(fields: [salesOrderId], references: [id])
  warehouse     WarehouseMaster?  @relation(fields: [warehouseId], references: [id])
  items         PackingListItem[]
  dispatchNotes DispatchNote[]

  @@index([companyId])
  @@index([plNo])
}

model PackingListItem {
  id               String   @id @default(cuid())
  packingListId    String
  inventoryStockId String
  heatNo           String?
  sizeLabel        String?
  material         String?
  quantityMtr      Decimal  @db.Decimal(10, 3)
  pieces           Int      @default(0)
  bundleNo         String?
  grossWeightKg    Decimal? @db.Decimal(10, 3)
  netWeightKg      Decimal? @db.Decimal(10, 3)
  markingDetails   String?
  dimensions       String?

  // Relations
  packingList    PackingList    @relation(fields: [packingListId], references: [id], onDelete: Cascade)
  inventoryStock InventoryStock @relation(fields: [inventoryStockId], references: [id])

  @@index([packingListId])
}

model DispatchNote {
  id                String    @id @default(cuid())
  companyId         String?
  dnNo              String    @unique
  dispatchDate      DateTime  @default(now())
  packingListId     String
  salesOrderId      String
  warehouseId       String?
  dispatchAddressId String?
  vehicleNo         String?
  lrNo              String?
  lrDate            DateTime?
  transporterId     String?
  destination       String?
  ewayBillNo        String?
  remarks           String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  company         CompanyMaster?           @relation(fields: [companyId], references: [id])
  packingList     PackingList              @relation(fields: [packingListId], references: [id])
  salesOrder      SalesOrder               @relation(fields: [salesOrderId], references: [id])
  warehouse       WarehouseMaster?         @relation(fields: [warehouseId], references: [id])
  dispatchAddress CustomerDispatchAddress? @relation(fields: [dispatchAddressId], references: [id])
  transporter     TransporterMaster?       @relation(fields: [transporterId], references: [id])
  invoices        Invoice[]

  @@index([companyId])
  @@index([dnNo])
  @@index([dispatchAddressId])
}

model Invoice {
  id                String        @id @default(cuid())
  companyId         String?
  invoiceNo         String        @unique
  invoiceDate       DateTime      @default(now())
  invoiceType       InvoiceType   @default(DOMESTIC)
  dispatchNoteId    String?
  salesOrderId      String
  customerId        String
  warehouseId       String?
  dispatchAddressId String?
  originalInvoiceId String?
  subtotal          Decimal       @db.Decimal(14, 2)
  cgst              Decimal       @default(0) @db.Decimal(14, 2)
  sgst              Decimal       @default(0) @db.Decimal(14, 2)
  igst              Decimal       @default(0) @db.Decimal(14, 2)
  totalAmount       Decimal       @db.Decimal(14, 2)
  currency          String        @default("INR")
  tcsAmount         Decimal       @default(0) @db.Decimal(14, 2)
  roundOff          Decimal       @default(0) @db.Decimal(10, 2)
  amountInWords     String?
  placeOfSupply     String?
  customerGstin     String?
  dueDate           DateTime?
  eWayBillNo        String?
  status            InvoiceStatus @default(DRAFT)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  company         CompanyMaster?           @relation(fields: [companyId], references: [id])
  dispatchNote    DispatchNote?            @relation(fields: [dispatchNoteId], references: [id])
  salesOrder      SalesOrder               @relation(fields: [salesOrderId], references: [id])
  customer        CustomerMaster           @relation(fields: [customerId], references: [id])
  warehouse       WarehouseMaster?         @relation(fields: [warehouseId], references: [id])
  dispatchAddress CustomerDispatchAddress? @relation(fields: [dispatchAddressId], references: [id])
  originalInvoice Invoice?                 @relation("CreditDebitNoteLink", fields: [originalInvoiceId], references: [id])
  linkedNotes     Invoice[]                @relation("CreditDebitNoteLink")
  items           InvoiceItem[]
  paymentReceipts PaymentReceipt[]
  emailLogs       InvoiceEmailLog[]

  @@index([companyId])
  @@index([invoiceNo])
  @@index([customerId])
  @@index([originalInvoiceId])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  sNo         Int
  description String?
  heatNo      String?
  sizeLabel   String?
  uom         String?
  quantity    Decimal  @db.Decimal(10, 3)
  unitRate    Decimal  @db.Decimal(12, 2)
  amount      Decimal  @db.Decimal(14, 2)
  hsnCode     String?
  taxRate     Decimal? @db.Decimal(5, 2)

  // Relations
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model InvoiceEmailLog {
  id           String         @id @default(cuid())
  invoiceId    String
  sentTo       String
  sentCc       String?
  subject      String
  messageBody  String         @db.Text
  sentById     String?
  sentAt       DateTime       @default(now())
  status       EmailLogStatus
  errorMessage String?        @db.Text

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  sentBy  User?   @relation("InvoiceEmailSentBy", fields: [sentById], references: [id])

  @@index([invoiceId])
  @@index([sentById])
}

model PaymentReceipt {
  id             String      @id @default(cuid())
  companyId      String?
  receiptNo      String      @unique
  receiptDate    DateTime    @default(now())
  invoiceId      String
  customerId     String
  amountReceived Decimal     @db.Decimal(14, 2)
  paymentMode    PaymentMode @default(NEFT)
  referenceNo    String?
  bankName       String?
  chequeNo       String?
  chequeDate     DateTime?
  tdsAmount      Decimal     @default(0) @db.Decimal(14, 2)
  remarks        String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  company  CompanyMaster? @relation(fields: [companyId], references: [id])
  invoice  Invoice        @relation(fields: [invoiceId], references: [id])
  customer CustomerMaster @relation(fields: [customerId], references: [id])

  @@index([companyId])
  @@index([receiptNo])
  @@index([invoiceId])
}

// ==================== CUSTOMER CONTACTS (COMPANY DIRECTORY) ====================

model CustomerContact {
  id          String            @id @default(cuid())
  customerId  String
  contactName String
  designation String?
  email       String?
  phone       String?
  department  ContactDepartment
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  customer CustomerMaster @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([department])
}

// ==================== PO ACCEPTANCE ====================

model POAcceptance {
  id                    String   @id @default(cuid())
  companyId             String?
  acceptanceNo          String   @unique
  clientPurchaseOrderId String   @unique
  acceptanceDate        DateTime
  committedDeliveryDate DateTime
  remarks               String?  @db.Text
  attachmentUrl         String?

  // Contact details (stored inline for document integrity)
  followUpName  String?
  followUpEmail String?
  followUpPhone String?
  qualityName   String?
  qualityEmail  String?
  qualityPhone  String?
  accountsName  String?
  accountsEmail String?
  accountsPhone String?

  status      String   @default("DRAFT")
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  company             CompanyMaster?      @relation(fields: [companyId], references: [id])
  clientPurchaseOrder ClientPurchaseOrder @relation(fields: [clientPurchaseOrderId], references: [id])
  createdBy           User                @relation("POACreatedBy", fields: [createdById], references: [id])

  @@index([companyId])
  @@index([clientPurchaseOrderId])
  @@index([acceptanceNo])
}

// ==================== WAREHOUSE INTIMATION (MPR) ====================

model WarehouseIntimation {
  id             String      @id @default(cuid())
  companyId      String?
  mprNo          String      @unique
  mprDate        DateTime    @default(now())
  salesOrderId   String
  warehouseId    String?
  priority       MPRPriority @default(NORMAL)
  requiredByDate DateTime?
  status         MPRStatus   @default(PENDING)
  remarks        String?     @db.Text
  createdById    String
  assignedToId   String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  company    CompanyMaster?            @relation(fields: [companyId], references: [id])
  salesOrder SalesOrder                @relation(fields: [salesOrderId], references: [id])
  warehouse  WarehouseMaster?          @relation(fields: [warehouseId], references: [id])
  createdBy  User                      @relation("MPRCreatedBy", fields: [createdById], references: [id])
  assignedTo User?                     @relation("MPRAssignedTo", fields: [assignedToId], references: [id])
  items      WarehouseIntimationItem[]

  @@index([companyId])
  @@index([salesOrderId])
  @@index([warehouseId])
  @@index([status])
  @@index([mprNo])
}

model WarehouseIntimationItem {
  id                    String         @id @default(cuid())
  warehouseIntimationId String
  sNo                   Int
  salesOrderItemId      String?
  product               String?
  material              String?
  sizeLabel             String?
  additionalSpec        String?
  requiredQty           Decimal        @db.Decimal(10, 3)
  preparedQty           Decimal        @default(0) @db.Decimal(10, 3)
  inspectionStatus      MPRCheckStatus @default(PENDING)
  testingStatus         MPRCheckStatus @default(PENDING)
  itemStatus            MPRItemStatus  @default(PENDING)
  inventoryStockId      String?
  heatNo                String?
  remarks               String?

  // Relations
  warehouseIntimation WarehouseIntimation @relation(fields: [warehouseIntimationId], references: [id], onDelete: Cascade)
  salesOrderItem      SalesOrderItem?     @relation(fields: [salesOrderItemId], references: [id])
  inventoryStock      InventoryStock?     @relation(fields: [inventoryStockId], references: [id])

  @@index([warehouseIntimationId])
  @@index([salesOrderItemId])
  @@index([inventoryStockId])
}

// ==================== ALERTS ====================

model Alert {
  id             String        @id @default(cuid())
  companyId      String?
  type           AlertType
  title          String
  message        String        @db.Text
  severity       AlertSeverity @default(MEDIUM)
  status         AlertStatus   @default(UNREAD)
  relatedModule  String?
  relatedId      String?
  dueDate        DateTime?
  assignedToRole UserRole?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  company CompanyMaster? @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([type])
  @@index([severity])
  @@index([assignedToRole])
}

// ==================== SYSTEM TABLES ====================

model AuditLog {
  id        String      @id @default(cuid())
  companyId String?
  tableName String
  recordId  String
  action    AuditAction
  fieldName String?
  oldValue  String?
  newValue  String?
  userId    String?
  timestamp DateTime    @default(now())
  ipAddress String?

  // Relations
  company CompanyMaster? @relation(fields: [companyId], references: [id])
  user    User?          @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([tableName, recordId])
  @@index([userId])
  @@index([timestamp])
}

model DocumentSequence {
  id            String  @id @default(cuid())
  companyId     String?
  documentType  String
  prefix        String
  currentNumber Int     @default(0)
  financialYear String
  resetMonth    Int     @default(4)

  company CompanyMaster? @relation(fields: [companyId], references: [id])

  @@unique([companyId, documentType])
  @@index([companyId])
  @@index([documentType])
}
